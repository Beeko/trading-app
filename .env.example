# ── Broker API ──
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Trading mode ──
TRADING_MODE=paper
# paper = simulated trades against real data
# live  = real trades through broker API

# ── Daily goals & risk ──
DAILY_PROFIT_TARGET=200.00
DAILY_LOSS_LIMIT_PCT=2.0
MAX_SINGLE_TRADE_RISK_PCT=1.0
MAX_POSITION_PCT=10.0
MAX_SECTOR_EXPOSURE_PCT=25.0
MAX_OPEN_POSITIONS=10
RISK_PROFILE=conservative

# ── News & sentiment ──
FINNHUB_API_KEY=your_finnhub_key
BENZINGA_API_KEY=your_benzinga_key
SENTIMENT_MODEL=local
# local = lightweight model, api = LLM API call

# ── Dashboard ──
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=3000

# ── Database ──
DATABASE_URL=sqlite:///data/trades.db

# ── Scheduling intervals (seconds) ──
MARKET_DATA_INTERVAL=5
NEWS_POLL_INTERVAL=300
SOCIAL_POLL_INTERVAL=120
INDICATOR_RECALC_INTERVAL=10

# ── Logging ──
LOG_LEVEL=INFO
LOG_DIR=data/logs
